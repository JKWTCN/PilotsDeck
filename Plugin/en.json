{
  "Name": "PilotsDock",
  "Description": "Directly control your FlightSim from your StreamDock! Map Actions to Sim Events and show Sim Variables on the Buttons.\n\nNOTE FOR UPGRADES: Please use the Installer from the GitHub Page (under Releases)!",
  "Category": "PilotsDock",
  "com.extension.pilotsdeck.action.display": {
    "Name": "Old Display Value (Deprecated)",
    "Tooltip": "Old Display Value Action without Command"
  },
  "com.extension.pilotsdeck.action.display.switch": {
    "Name": "Display Value",
    "Tooltip": "The Display Value Action combined with a Simple Button"
  },
  "com.extension.pilotsdeck.action.switch": {
    "Name": "Simple Button",
    "Tooltip": "Like a static Joystick-Button, but can be used in MultiActions!"
  },
  "com.extension.pilotsdeck.action.switch.display": {
    "Name": "Dynamic Button",
    "Tooltip": "A Button with Status Indication of its current State in the Sim"
  },
  "com.extension.pilotsdeck.action.switch.korry": {
    "Name": "Korry Button",
    "Tooltip": "A Button with Status Indication, with two independent Halves (top, bottom)"
  },
  "com.extension.pilotsdeck.action.display.radio": {
    "Name": "COM Radio",
    "Tooltip": "Can display and swap your active & standby COM Frequencies"
  },
  "com.extension.pilotsdeck.action.display.gauge": {
    "Name": "Display Gauge",
    "Tooltip": "Display a Value on a Bar or Arc"
  },
  "com.extension.pilotsdeck.action.display.gauge.dual": {
    "Name": "Display Gauge (Dual)",
    "Tooltip": "A graphical representation of two Values"
  },
  "com.extension.pilotsdeck.action.meta": {
    "Name": "Composite Action",
    "Tooltip": "Advanced Action composed of different Elements"
  },
  "com.extension.pilotsdeck.action.profile.switcher": {
    "Name": "Profile Switcher",
    "Tooltip": "Allows to switch between StreamDock Profiles based on the loaded Aircraft"
  },
